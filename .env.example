# ============================================================
# DaniClaw — Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=seu_token_aqui
# IDs dos usuários autorizados (separados por vírgula)
TELEGRAM_ALLOWED_USER_IDS=123456789

# --- LLM Providers ---
# Provedor ativo: "openai" | "gemini" | "deepseek" | "groq"
LLM_PROVIDER=openai

OPENAI_API_KEY=sua_chave_aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-2.0-flash-exp

DEEPSEEK_API_KEY=sua_chave_aqui
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

GROQ_API_KEY=sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Provedor para roteamento de skills (pode ser mais leve/barato)
SKILL_ROUTER_PROVIDER=openai

# --- Timezone ---
# Offset em horas em relação ao UTC (padrão: -3 = BRT)
# Pode ser alterado em runtime: "estou em Lisboa, ajuste o fuso"
TIMEZONE_OFFSET_HOURS=-3

# --- Feature Toggles ---
# Defina como false para desabilitar completamente o recurso
TOOL_FILE_ENABLED=true        # criar_arquivo, ler_arquivo
TOOL_REMINDERS_ENABLED=true   # agendar_lembrete + ReminderManager
TOOL_TIMEZONE_ENABLED=true    # definir_timezone
TOOL_SHELL_ENABLED=true       # executar_comando
TOOL_WEB_SEARCH_ENABLED=true  # pesquisar_internet (requer SERPER_API_KEY)
TOOL_RAG_ENABLED=true         # busca_semantica + indexar_documento (requer OPENAI_API_KEY)
SKILLS_ENABLED=true           # roteamento e carga de skills (.agents/skills/)
MEMORY_ENABLED=true           # histórico de conversão via SQLite
TTS_ENABLED=true              # detecção de pedidos de resposta em áudio
VOICE_ENABLED=true            # recebimento de mensagens de voz
DOCUMENT_ENABLED=true         # recebimento de arquivos/documentosMULTI_AGENT_ENABLED=true      # painel de 3 agentes para perguntas factuais
# --- Gmail IMAP ---
# Para configurar:
# 1. Ative a verificação em duas etapas na conta Google
# 2. Gere uma App Password: myaccount.google.com/apppasswords
# 3. Ative IMAP no Gmail: Settings > Forwarding & POP/IMAP > Enable IMAP
GMAIL_ENABLED=false
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# IDs dos chats que receberão notificações (separados por vírgula)
GMAIL_NOTIFY_CHAT_IDS=123456789
# Intervalo de verificação em segundos (padrão: 60)
GMAIL_POLL_INTERVAL_SEC=60

# --- RAG / Embeddings ---
# Modelo de embeddings para busca semântica (requer OPENAI_API_KEY).
# text-embedding-3-small = 1536 dims, ~$0.02/1M tokens (mais barato).
# text-embedding-3-large = 3072 dims, maior precisão.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# --- Web Search ---
# Crie sua chave gratuita em https://serper.dev (2.500 buscas/mês, sem cartão)
SERPER_API_KEY=sua_chave_aqui

# --- Shell ---
# Comandos permitidos (separados por vírgula). Deixe vazio para permitir tudo.
# Exemplo restritivo: SHELL_ALLOWED_COMMANDS=ls,cat,df,free,uptime,git,systemctl
SHELL_ALLOWED_COMMANDS=

# --- Agent Loop ---
MAX_ITERATIONS=8

# --- Memory ---
# Número de mensagens recentes para o contexto da IA
MEMORY_WINDOW_SIZE=20
# Caminho do banco SQLite
DB_PATH=./data/daniclaw.db

# --- Paths ---
TMP_DIR=./tmp
SKILLS_DIR=./.agents/

# --- TTS ---
# Voz padrão para síntese de fala (edge-tts)
TTS_VOICE=pt-BR-ThalitaMultilingualNeural

# --- Whisper STT ---
# Modelo OpenAI Whisper API (sempre whisper-1)
WHISPER_MODEL=whisper-1
# Idioma esperado (pt = português, en = inglês, deixe vazio para auto-detect)
WHISPER_LANGUAGE=pt
